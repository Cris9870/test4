APP_NAME="Reversa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# En local: http://localhost:8000  |  En Plesk: https://tu-dominio
APP_URL=http://localhost:8000
# ASSET_URL solo en produccion (Plesk): https://tu-dominio  (que @vite resuelva /build)
ASSET_URL=

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- PostgreSQL (Eloquent) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=tienda
DB_USERNAME=tienda
DB_PASSWORD=

# Sin auth/carrito: sesion y cache en ficheros (no dependemos de tablas extra)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Indexacion SINCRONA: sin worker de cola en este test
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log

# --- Buscador: Laravel Scout -> Meilisearch ---
SCOUT_DRIVER=meilisearch
# IMPORTANTE: indexacion sincrona (NO depende de un worker de cola)
SCOUT_QUEUE=false
# En local y en Plesk Meili suele correr en loopback:
MEILISEARCH_HOST=http://127.0.0.1:7700
# Master key de Meilisearch (NO se sube al repo)
MEILISEARCH_KEY=

VITE_APP_NAME="${APP_NAME}"
